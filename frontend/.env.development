# Cross-origin (CORS + session cookie): full backend origin, no trailing slash.
VITE_API_BASE=https://localhost:7154

# Same-origin via Vite proxy: leave empty — then /api is proxied to https://localhost:7154
# (session cookies from the backend are not sent by the browser on localhost:5173; use CORS mode for cookie login.)
# VITE_API_BASE=
